# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — shown as a link in the footer if set
NEXT_PUBLIC_TWITTER_URL=

# Optional — shown on the About page if set
NEXT_PUBLIC_GITHUB_URL=

# Telegram bot — see TELEGRAM_SETUP.md for how to get these
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
CRON_SECRET=

# Supabase → Project Settings → API → service_role key.
# SECRET — server-only, never exposed to the browser. Needed for the
# Telegram webhook, the reminder cron job, and admin broadcasts.
SUPABASE_SERVICE_ROLE_KEY=
